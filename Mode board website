/* Base Styles */

body {

  background-color: var(--color-background);

  color: var(--color-text);

  font-family: var(--font-sans);

  overflow-x: hidden;

}



/* Custom Scrollbar for that "Luxury" feel */

::-webkit-scrollbar {

  width: 6px;

}

::-webkit-scrollbar-track {

  background: var(--color-neutral-dark);

}

::-webkit-scrollbar-thumb {

  background: var(--color-primary);

  border-radius: 10px;

}



/* Glassmorphism Utilities */

.glass-panel {

  background: rgba(11, 12, 20, 0.7);

  backdrop-filter: blur(12px);

  border: 1px solid rgba(255, 255, 255, 0.05);

}



.input-field {

  @apply w-full bg-neutral-dark border border-neutral/20 rounded-lg px-4 py-3 focus:outline-none focus:border-primary transition-colors text-text placeholder-neutral/50;

}



.btn-primary {

  @apply bg-primary text-white px-6 py-2 rounded-lg hover:brightness-110 transition-all active:scale-95 font-medium;

}



/* The "Bilyzna" DNA */

